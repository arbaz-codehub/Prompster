<div class="bg-gray-50 dark:bg-[#111111] rounded-xl border border-gray-200 dark:border-white/10 overflow-hidden shadow-xl">
    <div class="p-6 border-b border-gray-200 dark:border-white/10 flex justify-between items-center bg-gray-50 dark:bg-[#111111]">
        <div>
            <h3 class="text-xl font-semibold text-black dark:text-white">Products</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Manage your digital assets and prompts</p>
        </div>
        <a href="/admin/products/new" class="flex items-center gap-2 px-4 py-2 bg-black text-white hover:bg-gray-800 dark:bg-white dark:text-black dark:hover:bg-gray-200 text-sm font-medium rounded-lg transition-colors shadow-lg shadow-blue-900/20">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            Add New Product
        </a>
    </div>

    <% if (products.length > 0) { %>
    <div class="overflow-x-auto">
        <table class="w-full text-left text-sm text-gray-500 dark:text-gray-400">
            <thead class="bg-gray-200 dark:bg-gray-800/50 text-gray-800 dark:text-gray-200 uppercase text-xs font-semibold tracking-wider">
                <tr>
                    <th class="px-6 py-4">Image</th>
                    <th class="px-6 py-4">Product Details</th>
                    <th class="px-6 py-4">Type</th>
                    <th class="px-6 py-4">Price</th>
                    <th class="px-6 py-4">Order</th>
                    <th class="px-6 py-4 text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-700">
                <% products.forEach(product => { %>
                <tr class="hover:bg-gray-200 dark:hover:bg-gray-800/80 transition-colors group">
                    <td class="px-6 py-4">
                        <div class="w-12 h-12 rounded-lg overflow-hidden border border-gray-300 dark:border-white/20 bg-gray-200 dark:bg-gray-800">
                            <img src="<%= product.image %>" alt="" class="w-full h-full object-cover">
                        </div>
                    </td>
                    <td class="px-6 py-4">
                        <div class="font-medium text-black group-hover:text-black dark:text-white dark:group-hover:text-white text-base mb-1"><%= product.title %></div>
                        <div class="text-xs text-gray-500 truncate max-w-[200px]"><%= product.desc %></div>
                    </td>
                    <td class="px-6 py-4">
                        <div class="flex flex-wrap gap-2">
                             <span class="px-2.5 py-1 rounded-full text-xs font-medium 
                                <%= product.type === 'Prompts' ? 'bg-purple-500/10 text-purple-400 border border-purple-500/20' : 
                                   product.type === 'Asset' ? 'bg-green-500/10 text-green-400 border border-green-500/20' : 
                                   'bg-gray-800 text-white dark:bg-gray-100 dark:text-black border border-transparent' %>">
                                <%= product.type || 'Standard' %>
                            </span>
                            <% if (product.isFree) { %>
                                <span class="px-2 py-1 rounded-full text-[10px] uppercase font-bold bg-green-500 text-black">Free</span>
                            <% } %>
                            <% if (product.isBestSeller) { %>
                                <span class="px-2 py-1 rounded-full text-[10px] uppercase font-bold bg-yellow-500 text-black" title="Best Seller">★ Best</span>
                            <% } %>
                            <% if (product.isDailyDrop) { %>
                                <span class="px-2 py-1 rounded-full text-[10px] uppercase font-bold bg-purple-500 text-black dark:text-white" title="Daily Drop">droplet</span>
                            <% } %>
                        </div>
                    </td>
                    <td class="px-6 py-4 font-medium text-black group-hover:text-black dark:text-white dark:group-hover:text-white">₹<%= product.price.toLocaleString('en-IN') %></td>
                    <td class="px-6 py-4 text-gray-500 dark:text-gray-400"><%= product.displayOrder || 0 %></td>
                    <td class="px-6 py-4">
                        <div class="flex items-center justify-end gap-3 opacity-60 group-hover:opacity-100 transition-opacity">
                            <a href="/admin/products/<%= product._id %>/edit" class="p-2 text-gray-500 hover:text-black dark:text-gray-400 dark:hover:text-white hover:bg-gray-200 dark:hover:bg-gray-700 rounded-lg transition-colors" title="Edit">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                            </a>
                            <form action="/admin/products/<%= product._id %>/duplicate" method="POST" style="margin:0;">
                                <button type="submit" class="p-2 text-green-400 hover:bg-green-500/10 rounded-lg transition-colors" title="Duplicate">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path><rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect></svg>
                                </button>
                            </form>
                            <form action="/admin/products/<%= product._id %>/delete" method="POST" onsubmit="return confirm('Are you sure you want to delete this product? This action cannot be undone.');" style="margin:0;">
                                <button type="submit" class="p-2 text-red-400 hover:bg-red-500/10 rounded-lg transition-colors" title="Delete">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
    <% } else { %>
    <div class="p-12 text-center">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gray-200 dark:bg-gray-800/50 mb-4 text-gray-500">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
        </div>
        <h3 class="text-black dark:text-white font-medium text-lg mb-1">No products found</h3>
        <p class="text-gray-500 dark:text-gray-400 text-sm mb-6">Get started by creating your first product.</p>
        <a href="/admin/products/new" class="px-6 py-2 bg-black text-white hover:bg-gray-800 dark:bg-white dark:text-black dark:hover:bg-gray-200 text-sm font-medium rounded-lg transition-colors">Create Product</a>
    </div>
    <% } %>
</div>
