<div class="max-w-4xl mx-auto bg-gray-50 dark:bg-[#111111] rounded-xl border border-gray-200 dark:border-white/10 p-8 shadow-2xl">
    <div class="mb-8 flex justify-between items-center">
        <div>
            <a href="/admin/products" class="text-gray-500 dark:text-gray-400 hover:text-black dark:text-white text-sm mb-2 inline-block transition-colors">&larr; Back to Products</a>
            <h2 class="text-2xl font-bold text-black dark:text-white"><%= product._id ? 'Edit Product' : 'New Product' %></h2>
        </div>
        <% if (product._id) { %>
            <span class="px-3 py-1 bg-blue-900/50 text-black dark:text-white border border-black dark:border-white/20 rounded-full text-xs font-mono">ID: <%= product._id %></span>
        <% } %>
    </div>

    <form action="<%= action %>" method="POST" class="space-y-8">
        
        <!-- Basic Info -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="md:col-span-2">
                <label class="block text-sm font-medium text-gray-500 dark:text-gray-400 mb-2">Title</label>
                <input type="text" name="title" value="<%= product.title || '' %>" class="w-full bg-white dark:bg-[#0a0a0a] border border-gray-200 dark:border-white/10 rounded-lg p-3 text-black dark:text-white focus:border-black dark:border-white focus:ring-1  transition-colors" required>
            </div>
            
            <div>
                <label class="block text-sm font-medium text-gray-500 dark:text-gray-400 mb-2">Type</label>
                <select name="type" class="w-full bg-white dark:bg-[#0a0a0a] border border-gray-200 dark:border-white/10 rounded-lg p-3 text-black dark:text-white focus:border-black dark:border-white focus:ring-1  transition-colors">
                    <% typeOptions.forEach(opt => { %>
                        <option value="<%= opt %>" <%= product.type === opt ? 'selected' : '' %>><%= opt %></option>
                    <% }) %>
                </select>
            </div>

            <!-- Removed Format Field (Moved to Dynamic Section) -->
        </div>

        <!-- Pricing Section -->
        <div class="bg-gray-100 dark:bg-[#151515]/50 rounded-xl border border-gray-200 dark:border-white/10/50 p-6 space-y-6">
            <div class="flex items-center justify-between">
                <h3 class="text-black dark:text-white font-medium flex items-center gap-2">
                    <span class="iconify text-green-400" data-icon="lucide:dollar-sign"></span>
                    Pricing & Links
                </h3>
                <label class="flex items-center cursor-pointer gap-3">
                    <span class="text-sm font-medium text-gray-600 dark:text-gray-300">Make Free?</span>
                    <div class="relative">
                        <input type="checkbox" id="isFreeToggle" name="isFree" class="sr-only" value="true" <%= product.isFree ? 'checked' : '' %>>
                        <div class="block bg-gray-300 dark:bg-gray-700 w-10 h-6 rounded-full transition-colors toggle-bg"></div>
                        <div class="dot absolute left-1 top-1 bg-white w-4 h-4 rounded-full transition-transform"></div>
                    </div>
                </label>
            </div>

            <div id="pricing-fields" class="grid grid-cols-1 md:grid-cols-2 gap-6 transition-all duration-300 <%= product.isFree ? 'opacity-50 pointer-events-none grayscale' : '' %>">
                <div>
                    <label class="block text-xs uppercase tracking-wide text-gray-500 mb-1.5">Selling Price (INR)</label>
                    <div class="relative">
                        <span class="absolute left-3 top-3 text-gray-500">₹</span>
                        <input type="number" step="0.01" name="price" value="<%= product.price || 0 %>" class="w-full bg-white dark:bg-[#0a0a0a] border border-gray-200 dark:border-white/10 rounded-lg py-2.5 pl-8 pr-3 text-black dark:text-white focus:border-black dark:border-white focus:ring-1 ">
                    </div>
                </div>
                 <div>
                    <label class="block text-xs uppercase tracking-wide text-gray-500 mb-1.5">Selling Price (USD)</label>
                    <div class="relative">
                        <span class="absolute left-3 top-3 text-gray-500">$</span>
                        <input type="number" step="0.01" name="priceUsd" value="<%= product.priceUsd || 0 %>" class="w-full bg-white dark:bg-[#0a0a0a] border border-gray-200 dark:border-white/10 rounded-lg py-2.5 pl-8 pr-3 text-black dark:text-white focus:border-black dark:border-white focus:ring-1 ">
                    </div>
                </div>
                <div class="md:col-span-2">
                    <label class="block text-xs uppercase tracking-wide text-gray-500 mb-1.5">Discount Percentage (%)</label>
                    <div class="relative">
                        <span class="absolute right-3 top-3 text-gray-500">%</span>
                        <input type="number" step="1" min="0" max="100" name="discountPercentage" value="<%= product.discountPercentage || 0 %>" class="w-full bg-white dark:bg-[#0a0a0a] border border-gray-200 dark:border-white/10 rounded-lg py-2.5 px-3 text-black dark:text-white focus:border-black dark:border-white focus:ring-1 " placeholder="e.g. 20 for 20% off">
                    </div>
                    <p class="text-xs text-gray-500 mt-1">If set above 0, this will automatically calculate and display the slashed original price on the frontend.</p>
                </div>
                 <div>
                    <label class="block text-xs uppercase tracking-wide text-gray-500 mb-1.5">Payment Link (INR)</label>
                     <input type="url" name="linkInr" value="<%= product.linkInr || '' %>" class="w-full bg-white dark:bg-[#0a0a0a] border border-gray-200 dark:border-white/10 rounded-lg p-2.5 text-black dark:text-white focus:border-black dark:border-white focus:ring-1 " placeholder="https://razorpay.me/...">
                </div>
                 <div>
                    <label class="block text-xs uppercase tracking-wide text-gray-500 mb-1.5">Payment Link (USD)</label>
                     <input type="url" name="linkUsd" value="<%= product.linkUsd || '' %>" class="w-full bg-white dark:bg-[#0a0a0a] border border-gray-200 dark:border-white/10 rounded-lg p-2.5 text-black dark:text-white focus:border-black dark:border-white focus:ring-1 " placeholder="https://gumroad.com/...">
                </div>
            </div>
            
            <div id="free-message" class="text-center py-2 text-green-400 text-sm <%= product.isFree ? '' : 'hidden' %>">
                <span class="iconify inline mr-1" data-icon="lucide:check-circle"></span>
                Product is set to Free. Email capture will be enabled automatically.
            </div>
        </div>

        <!-- Exclusivity Flags -->
        <div class="bg-blue-900/10 rounded-xl border border-black dark:border-white/10 p-6">
            <h3 class="text-black dark:text-white font-medium mb-4 text-sm uppercase tracking-wide">Homepage Visibility</h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <!-- Best Seller Toggle -->
                <div class="flex items-center justify-between p-3 bg-gray-50 dark:bg-[#111111] rounded-lg border border-gray-200 dark:border-white/10">
                    <span class="text-sm text-gray-800 dark:text-gray-200">Best Seller</span>
                    <label class="relative cursor-pointer">
                        <input type="checkbox" name="isBestSeller" class="sr-only flag-toggle" value="true" <%= product.isBestSeller ? 'checked' : '' %>>
                        <div class="block bg-gray-300 dark:bg-gray-700 w-10 h-6 rounded-full transition-colors toggle-bg"></div>
                        <div class="dot absolute left-1 top-1 bg-white w-4 h-4 rounded-full transition-transform"></div>
                    </label>
                </div>

                <!-- Daily Drop Toggle -->
                <div class="flex items-center justify-between p-3 bg-gray-50 dark:bg-[#111111] rounded-lg border border-gray-200 dark:border-white/10">
                    <span class="text-sm text-gray-800 dark:text-gray-200">Daily Drop</span>
                    <label class="relative cursor-pointer">
                        <input type="checkbox" name="isDailyDrop" class="sr-only flag-toggle" value="true" <%= product.isDailyDrop ? 'checked' : '' %>>
                        <div class="block bg-gray-300 dark:bg-gray-700 w-10 h-6 rounded-full transition-colors toggle-bg"></div>
                        <div class="dot absolute left-1 top-1 bg-white w-4 h-4 rounded-full transition-transform"></div>
                    </label>
                </div>

                <!-- Featured Toggle -->
                <div class="flex items-center justify-between p-3 bg-gray-50 dark:bg-[#111111] rounded-lg border border-gray-200 dark:border-white/10">
                    <span class="text-sm text-gray-800 dark:text-gray-200">Featured</span>
                    <label class="relative cursor-pointer">
                        <input type="checkbox" name="isFeatured" class="sr-only flag-toggle" value="true" <%= product.isFeatured ? 'checked' : '' %>>
                        <div class="block bg-gray-300 dark:bg-gray-700 w-10 h-6 rounded-full transition-colors toggle-bg"></div>
                        <div class="dot absolute left-1 top-1 bg-white w-4 h-4 rounded-full transition-transform"></div>
                    </label>
                </div>
            </div>
            <p class="text-xs text-black dark:text-white/60 mt-3">* Enabling a flag here will automatically disable it for other products.</p>
        </div>

        <!-- Media & Description -->
        <div>
            <label class="block text-sm font-medium text-gray-500 dark:text-gray-400 mb-2">Image URL</label>
            <div class="flex gap-4">
                <input type="url" name="image" id="imgInput" value="<%= product.image || '' %>" class="flex-1 bg-white dark:bg-[#0a0a0a] border border-gray-200 dark:border-white/10 rounded-lg p-3 text-black dark:text-white focus:border-black dark:border-white focus:ring-1  transition-colors" placeholder="https://..." required>
                <div class="w-12 h-12 bg-gray-200 dark:bg-gray-800 rounded overflow-hidden border border-gray-300 dark:border-white/20 flex-shrink-0">
                    <img id="imgPreview" src="<%= product.image || '' %>" onerror="this.style.display='none'" onload="this.style.display='block'" class="w-full h-full object-cover">
                </div>
            </div>
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-500 dark:text-gray-400 mb-2">Description</label>
            <textarea name="desc" rows="4" class="w-full bg-white dark:bg-[#0a0a0a] border border-gray-200 dark:border-white/10 rounded-lg p-3 text-black dark:text-white focus:border-black dark:border-white focus:ring-1  transition-colors"><%= product.desc || '' %></textarea>
        </div>

        <!-- Dynamic Fields Container -->
        <div id="dynamic-fields" class="bg-gray-50 dark:bg-[#111111] rounded-xl border border-gray-200 dark:border-white/10/50 p-6 space-y-6">
            
            <!-- PROMPTS SPECIFIC FIELDS -->
            <div id="prompt-fields" class="hidden space-y-4">
                <div class="flex items-center gap-2 mb-2">
                    <span class="iconify text-purple-400" data-icon="lucide:sparkles"></span>
                    <h3 class="text-sm font-medium text-purple-300">Prompt Details</h3>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-gray-500 dark:text-gray-400 mb-2">Prompt Category</label>
                        <select name="category" id="promptCategory" class="w-full bg-white dark:bg-[#0a0a0a] border border-gray-200 dark:border-white/10 rounded-lg p-3 text-black dark:text-white focus:border-black dark:focus:border-white focus:outline-none transition-colors">
                            <% if(typeof promptCategoryOptions !== 'undefined') { %>
                                <% promptCategoryOptions.forEach(opt => { %>
                                    <option value="<%= opt %>" <%= product.category === opt ? 'selected' : '' %>><%= opt %></option>
                                <% }) %>
                            <% } %>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-500 dark:text-gray-400 mb-2">Subcategory</label>
                        <input type="text" name="subCategory" value="<%= product.subCategory || '' %>" class="w-full bg-white dark:bg-[#0a0a0a] border border-gray-200 dark:border-white/10 rounded-lg p-3 text-black dark:text-white focus:border-black dark:focus:border-white focus:outline-none" placeholder="e.g. Midjourney, Logo Design, Web Elements">
                    </div>
                </div>
            </div>

            <!-- ASSETS SPECIFIC FIELDS -->
            <div id="asset-fields" class="hidden space-y-4">
                <div class="flex items-center gap-2 mb-2">
                    <span class="iconify text-black dark:text-white" data-icon="lucide:package"></span>
                    <h3 class="text-sm font-medium text-black dark:text-white">Asset Details</h3>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-gray-500 dark:text-gray-400 mb-2">Marketplace Category</label>
                        <select name="category" id="assetCategory" class="w-full bg-white dark:bg-[#0a0a0a] border border-gray-200 dark:border-white/10 rounded-lg p-3 text-black dark:text-white focus:border-black dark:border-white transition-colors">
                            <option value="">Select Category</option>
                            <% if(typeof categoryOptions !== 'undefined') { %>
                                <% categoryOptions.forEach(opt => { %>
                                    <option value="<%= opt %>" <%= product.category === opt ? 'selected' : '' %>><%= opt %></option>
                                <% }) %>
                            <% } %>
                        </select>
                    </div>
                    <div id="format-wrapper">
                        <label class="block text-sm font-medium text-gray-500 dark:text-gray-400 mb-2">Format</label>
                        <select name="format" id="assetFormat" class="w-full bg-white dark:bg-[#0a0a0a] border border-gray-200 dark:border-white/10 rounded-lg p-3 text-black dark:text-white focus:border-black dark:border-white transition-colors">
                            <option value="">Select Format</option>
                            <% formatOptions.forEach(opt => { %>
                                <option value="<%= opt %>" <%= product.format === opt ? 'selected' : '' %>><%= opt %></option>
                            <% }) %>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <!-- Common Marketing Fields -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                 <label class="block text-sm font-medium text-gray-500 dark:text-gray-400 mb-2">Marketing Hook</label>
                <input type="text" name="hook" value="<%= product.hook || '' %>" class="w-full bg-white dark:bg-[#0a0a0a] border border-gray-200 dark:border-white/10 rounded-lg p-3 text-black dark:text-white focus:border-black dark:border-white" placeholder="e.g. 'Unleash your creativity'">
            </div>
             <div>
                <label class="block text-sm font-medium text-gray-500 dark:text-gray-400 mb-2">Badge / Tag</label>
                <input type="text" name="tag" value="<%= product.tag || '' %>" class="w-full bg-white dark:bg-[#0a0a0a] border border-gray-200 dark:border-white/10 rounded-lg p-3 text-black dark:text-white focus:border-black dark:border-white" placeholder="e.g. 'v2.0', '4K'">
             </div>
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-500 dark:text-gray-400 mb-2">What's Inside (Comma separated)</label>
            <textarea name="whatsInside" rows="3" class="w-full bg-white dark:bg-[#0a0a0a] border border-gray-200 dark:border-white/10 rounded-lg p-3 text-black dark:text-white focus:border-black dark:border-white focus:ring-1 "><%= product.whatsInside ? product.whatsInside.join(', ') : '' %></textarea>
        </div>
 
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
             <div>
                <label class="block text-sm font-medium text-gray-500 dark:text-gray-400 mb-2">Rating</label>
                <input type="number" step="0.1" name="rating" value="<%= product.rating || 5 %>" class="w-full bg-white dark:bg-[#0a0a0a] border border-gray-200 dark:border-white/10 rounded-lg p-3 text-black dark:text-white focus:border-black dark:border-white focus:ring-1 ">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-500 dark:text-gray-400 mb-2">Display Order</label>
                <input type="number" name="displayOrder" value="<%= product.displayOrder || 0 %>" class="w-full bg-white dark:bg-[#0a0a0a] border border-gray-200 dark:border-white/10 rounded-lg p-3 text-black dark:text-white focus:border-black dark:border-white focus:ring-1 ">
                <p class="text-xs text-gray-500 mt-1">Higher numbers appear first. Default is 0.</p>
            </div>
        </div>

        <!-- Manual Review Section -->
        <div class="bg-gray-100 dark:bg-[#151515]/50 rounded-xl border border-gray-200 dark:border-white/10/50 p-6 space-y-6">
            <h3 class="text-black dark:text-white font-medium flex items-center gap-2">
                <span class="iconify text-yellow-500" data-icon="lucide:star"></span>
                Add Manual Review
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-sm font-medium text-gray-500 dark:text-gray-400 mb-2">Reviewer Name</label>
                    <input type="text" name="reviewUser" class="w-full bg-white dark:bg-[#0a0a0a] border border-gray-200 dark:border-white/10 rounded-lg p-3 text-black dark:text-white focus:border-black dark:border-white focus:ring-1 " placeholder="e.g. John Doe">
                </div>
                <div>
                     <label class="block text-sm font-medium text-gray-500 dark:text-gray-400 mb-2">Rating</label>
                     <select name="reviewRating" class="w-full bg-white dark:bg-[#0a0a0a] border border-gray-200 dark:border-white/10 rounded-lg p-3 text-black dark:text-white focus:border-black dark:border-white">
                         <option value="5">5 Stars</option>
                         <option value="4">4 Stars</option>
                         <option value="3">3 Stars</option>
                         <option value="2">2 Stars</option>
                         <option value="1">1 Star</option>
                     </select>
                </div>
                <div class="md:col-span-2">
                    <label class="block text-sm font-medium text-gray-500 dark:text-gray-400 mb-2">Review Text</label>
                     <textarea name="reviewText" rows="2" class="w-full bg-white dark:bg-[#0a0a0a] border border-gray-200 dark:border-white/10 rounded-lg p-3 text-black dark:text-white focus:border-black dark:border-white focus:ring-1 " placeholder="e.g. 'Amazing product, improved my workflow!'"></textarea>
                     <p class="text-xs text-gray-500 mt-1">* Filling this will append a new review to the product.</p>
                </div>
            </div>
        </div>

        <div class="pt-8 border-t border-gray-200 dark:border-white/10 flex justify-end gap-4">
             <a href="/admin/products" class="px-6 py-3 border border-gray-300 dark:border-white/20 hover:bg-gray-200 dark:bg-gray-800 text-gray-600 dark:text-gray-300 font-medium rounded-lg transition-colors">Cancel</a>
            <button type="submit" class="px-8 py-3 bg-black text-white hover:bg-gray-800 dark:bg-white dark:text-black dark:hover:bg-gray-200 font-medium rounded-lg shadow-lg shadow-blue-900/20 transition-all hover:scale-[1.02]">Save Product</button>
        </div>

    </form>
    
    <!-- User Guide Section -->
    <div class="mt-12 pt-8 border-t border-gray-200 dark:border-white/10">
        <h3 class="text-xl font-semibold text-black dark:text-white mb-6 flex items-center gap-2">
            <span class="iconify text-black dark:text-white" data-icon="lucide:book-open"></span>
            Product Creation Guide
        </h3>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-sm text-gray-500 dark:text-gray-400">
            <div class="space-y-4">
                <div>
                    <h4 class="text-black dark:text-white font-medium mb-1">Basic Info & Type</h4>
                    <p>
                        <strong>Title & Description:</strong> Keep titles short and catchy. Descriptions should highlight key benefits.<br>
                        <strong>Type:</strong> Select 'Prompts' for AI text/image prompts. Select 'Other Assets' for files like LUTs, Presets, or Templates.<br>
                        <strong>Format:</strong> Specify the file format (e.g., PDF, TXT, ZIP) for clarity.
                    </p>
                </div>
                <div>
                    <h4 class="text-black dark:text-white font-medium mb-1">Pricing & Currency</h4>
                    <p>
                        <strong>INR Price:</strong> The main price displayed to Indian users.<br>
                        <strong>USD Price:</strong> The exact price in Dollar for international users. If left 0, it auto-calculates based on exchange rate (approx 1 USD = 84 INR), but it is recommended to set a fixed USD price.<br>
                        <strong>Is Free:</strong> If checked, the product shows as "Free" and collects emails instead of payments.
                    </p>
                </div>
            </div>
            
            <div class="space-y-4">
                <div>
                    <h4 class="text-black dark:text-white font-medium mb-1">Visibility & Badges</h4>
                    <p>
                        <strong>Best Seller:</strong> Highlights one top product on the homepage. <span class="text-yellow-500">Only one product should have this flag active at a time.</span><br>
                        <strong>Daily Free Drop:</strong> The featured free item on the homepage. Adds a "Free for Today" badge. <span class="text-purple-400">Only one product should be the Daily Drop.</span><br>
                        <strong>Featured:</strong> Shows in the special "Featured Collection" section.
                    </p>
                </div>
                <div>
                    <h4 class="text-black dark:text-white font-medium mb-1">Assets & Links</h4>
                    <p>
                        <strong>Wait for Inside:</strong> List key components (e.g., "10 Presets, Installation Guide").<br>
                        <strong>Payment Links:</strong> Direct links to your payment gateway (Stripe/Razorpay) for paid products.<br>
                        <strong>Download Link:</strong> Direct Google Drive/Dropbox link for free items or digital assets.
                    </p>
                </div>
            </div>
        </div>
    </div>

</div>

<style>
    /* Toggle switch styles */
    /* Generic toggle styles */
    .sr-only:checked ~ .toggle-bg {
        background-color: #22c55e;
    }
    .sr-only:checked ~ .dot {
        transform: translateX(100%);
    }
    
    /* Specific overrides if needed */
    input[name="isDailyDrop"]:checked ~ .toggle-bg {
        background-color: #a855f7; /* Purple */
    }
    input[name="isFeatured"]:checked ~ .toggle-bg {
        background-color: #eab308; /* Yellow */
    }
</style>

<script>
    const toggle = document.getElementById('isFreeToggle');
    const pricingFields = document.getElementById('pricing-fields');
    const freeMsg = document.getElementById('free-message');

    if(toggle) {
        toggle.addEventListener('change', () => {
            if(toggle.checked) {
                pricingFields.classList.add('opacity-50', 'pointer-events-none', 'grayscale');
                freeMsg.classList.remove('hidden');
            } else {
                pricingFields.classList.remove('opacity-50', 'pointer-events-none', 'grayscale');
                freeMsg.classList.add('hidden');
            }
        });
    }

    // Simple img preview
    const imgInput = document.getElementById('imgInput');
    const imgPreview = document.getElementById('imgPreview');
    if(imgInput) {
        imgInput.addEventListener('input', () => {
            imgPreview.src = imgInput.value;
            imgPreview.style.display = 'block';
        });
    }

    // Exclusivity Checkboxes (Mutually Exclusive)
    const exclusiveFlags = document.querySelectorAll('.flag-toggle');
    exclusiveFlags.forEach(flag => {
        flag.addEventListener('change', function() {
            if(this.checked) {
                exclusiveFlags.forEach(other => {
                    if(other !== this) other.checked = false;
                });
            }
        });
    });
    // Type Dependent Fields
    const typeSelect = document.querySelector('select[name="type"]');
    const promptFields = document.getElementById('prompt-fields');
    const assetFields = document.getElementById('asset-fields');
    
    // Inputs to toggle
    const promptInputs = promptFields.querySelectorAll('input, select');
    const assetInputs = assetFields.querySelectorAll('input, select');
    
    function updateFields() {
        const val = typeSelect.value;
        if(val === 'Prompts') {
            promptFields.classList.remove('hidden');
            assetFields.classList.add('hidden');
            promptInputs.forEach(el => el.disabled = false);
            assetInputs.forEach(el => el.disabled = true);
        } else {
            promptFields.classList.add('hidden');
            assetFields.classList.remove('hidden');
            promptInputs.forEach(el => el.disabled = true);
            assetInputs.forEach(el => el.disabled = false);
        }
    }
    
    if(typeSelect) {
        updateFields();
        typeSelect.addEventListener('change', updateFields);
    }
</script>
