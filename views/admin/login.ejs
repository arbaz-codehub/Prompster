<!DOCTYPE html>
<html lang="en">
<head>
    <script>
        let presetTheme = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        if(presetTheme === 'dark') document.documentElement.classList.add('dark');
    </script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Prompster Admin Login</title>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'sans-serif'] }
                }
            }
        }
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-gray-50 dark:bg-[#0a0a0a] flex items-center justify-center min-h-screen">

    <div class="max-w-md w-full p-8 relative">
        <!-- Logo -->
        <div class="flex justify-center mb-8">
            <img src="/logo.png" alt="Prompster" class="h-12 w-auto object-contain rounded-[50%]">
        </div>

        <!-- Login Form -->
        <form id="login-form" action="/admin/login" method="POST" class="space-y-6 bg-white dark:bg-[#0a0a0a] border border-gray-200 dark:border-white/10 rounded-2xl p-8 shadow-2xl relative z-10">
            <% if (error) { %>
                <div class="bg-red-500/10 border border-red-500/50 text-red-500 p-3 rounded text-sm text-center">
                    <%= error %>
                </div>
            <% } %>

            <div>
                <label class="block text-sm font-medium text-gray-500 dark:text-gray-400 mb-2">Password</label>
                <input type="password" name="password" required
                       class="w-full bg-white dark:bg-[#111111] border border-gray-200 dark:border-white/10 rounded-xl px-4 py-3 text-black dark:text-white focus:outline-none focus:border-black dark:border-white/50 transition-colors placeholder-gray-500"
                       placeholder="Enter password...">
            </div>

            <button type="submit" class="w-full bg-black text-white hover:bg-gray-800 dark:bg-white dark:text-black dark:hover:bg-gray-200 font-medium rounded-xl py-3 transition">Authenticate</button>
        </form>

        <!-- Secret Key Reset Modal (Hidden initially) -->
        <div id="reset-modal" class="<%= showReset ? 'flex' : 'hidden' %> fixed inset-0 z-50 items-center justify-center">
            <div class="absolute inset-0 bg-black/80 backdrop-blur-sm"></div>
            <div class="bg-white dark:bg-[#0a0a0a] border border-gray-200 dark:border-white/10 rounded-2xl p-8 max-w-sm w-full mx-4 relative z-10 shadow-2xl">
                <h3 class="text-xl font-bold text-black dark:text-white mb-4">Security verification required</h3>
                <p class="text-sm text-gray-500 dark:text-gray-400 mb-6">Too many incorrect attempts. Please enter your secret key to reset the password.</p>
                
                <form action="/admin/reset-password" method="POST" class="space-y-4">
                    <% if (resetError) { %>
                        <div class="bg-red-500/10 border border-red-500/50 text-red-500 p-2 rounded text-sm text-center"><%= resetError %></div>
                    <% } %>
                    <div>
                        <input type="password" name="secretKey" required placeholder="Secret Key" class="w-full bg-white dark:bg-[#111111] border border-gray-200 dark:border-white/10 rounded-xl px-4 py-3 text-black dark:text-white focus:outline-none focus:border-black dark:border-white/50 mb-4">
                        <input type="password" name="newPassword" required placeholder="New Password" class="w-full bg-white dark:bg-[#111111] border border-gray-200 dark:border-white/10 rounded-xl px-4 py-3 text-black dark:text-white focus:outline-none focus:border-black dark:border-white/50">
                    </div>
                    <button type="submit" class="w-full bg-black text-white hover:bg-gray-800 dark:bg-white dark:text-black dark:hover:bg-gray-200 font-medium rounded-xl py-3 transition">Reset Password</button>
                </form>
            </div>
        </div>
    </div>
</body>
</html>
