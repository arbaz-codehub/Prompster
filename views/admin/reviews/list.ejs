<div class="bg-gray-50 dark:bg-[#111111] rounded-xl border border-gray-200 dark:border-white/10 overflow-hidden shadow-xl">
    <div class="p-6 border-b border-gray-200 dark:border-white/10 flex justify-between items-center bg-gray-50 dark:bg-[#111111]">
        <div>
            <h3 class="text-xl font-semibold text-black dark:text-white">Reviews</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Manage customer testimonials</p>
        </div>
        <a href="/admin/reviews/new" class="flex items-center gap-2 px-4 py-2 bg-black text-white hover:bg-gray-800 dark:bg-white dark:text-black dark:hover:bg-gray-200 text-sm font-medium rounded-lg transition-colors shadow-lg shadow-blue-900/20">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            Add New Review
        </a>
    </div>

    <% if (reviews.length > 0) { %>
    <div class="overflow-x-auto">
        <table class="w-full text-left text-sm text-gray-500 dark:text-gray-400">
            <thead class="bg-gray-200 dark:bg-gray-800/50 text-gray-800 dark:text-gray-200 uppercase text-xs font-semibold tracking-wider">
                <tr>
                    <th class="px-6 py-4">Reviewer</th>
                    <th class="px-6 py-4">Rating</th>
                    <th class="px-6 py-4">Comment</th>
                    <th class="px-6 py-4 text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-700">
                <% reviews.forEach(review => { %>
                <tr class="hover:bg-gray-200 dark:bg-gray-800/30 transition-colors group">
                    <td class="px-6 py-4">
                        <div class="flex items-center gap-3">
                            <% if(review.avatar) { %>
                                <img src="<%= review.avatar %>" class="w-8 h-8 rounded-full object-cover border border-gray-300 dark:border-white/20">
                            <% } else { %>
                                <div class="w-8 h-8 rounded-full bg-gray-200 dark:bg-gray-800 flex items-center justify-center text-xs font-medium text-gray-600 dark:text-gray-300">
                                    <%= review.reviewerName.charAt(0) %>
                                </div>
                            <% } %>
                            <span class="font-medium text-black dark:text-white"><%= review.reviewerName %></span>
                        </div>
                    </td>
                    <td class="px-6 py-4">
                        <div class="flex text-yellow-400">
                            <% for(let i=0; i<review.rating; i++) { %>★<% } %>
                            <span class="text-gray-600 ml-1 text-xs">(<%= review.rating %>)</span>
                        </div>
                    </td>
                    <td class="px-6 py-4">
                        <p class="truncate max-w-xs" title="<%= review.comment %>"><%= review.comment %></p>
                    </td>
                    <td class="px-6 py-4">
                        <div class="flex items-center justify-end gap-3 opacity-60 group-hover:opacity-100 transition-opacity">
                            <a href="/admin/reviews/<%= review._id %>/edit" class="p-2 text-black dark:text-white hover:bg-black text-white hover:bg-gray-800 dark:bg-white dark:text-black dark:hover:bg-gray-200/10 rounded-lg transition-colors" title="Edit">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                            </a>
                            <form action="/admin/reviews/<%= review._id %>/delete" method="POST" onsubmit="return confirm('Delete this review?');" style="margin:0;">
                                <button type="submit" class="p-2 text-red-400 hover:bg-red-500/10 rounded-lg transition-colors" title="Delete">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
    <% } else { %>
    <div class="p-12 text-center">
        <p class="text-gray-500 dark:text-gray-400">No reviews yet.</p>
    </div>
    <% } %>
</div>
