<div class="max-w-2xl mx-auto bg-gray-50 dark:bg-[#111111] rounded-xl border border-gray-200 dark:border-white/10 p-8 shadow-2xl">
    <div class="mb-8">
        <a href="/admin/reviews" class="text-gray-500 dark:text-gray-400 hover:text-black dark:text-white text-sm mb-4 inline-block">&larr; Back to Reviews</a>
        <h2 class="text-2xl font-bold text-black dark:text-white"><%= review._id ? 'Edit Review' : 'New Review' %></h2>
    </div>

    <form action="<%= action %>" method="POST" class="space-y-6">
        
        <div>
            <label class="block text-sm font-medium text-gray-500 dark:text-gray-400 mb-2">Reviewer Name</label>
            <input type="text" name="reviewerName" value="<%= review.reviewerName || '' %>" class="w-full bg-white dark:bg-[#0a0a0a] border border-gray-200 dark:border-white/10 rounded-lg p-3 text-black dark:text-white focus:border-black dark:border-white focus:ring-1 " required>
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-500 dark:text-gray-400 mb-2">Rating (1-5)</label>
            <input type="number" name="rating" min="1" max="5" value="<%= review.rating || 5 %>" class="w-full bg-white dark:bg-[#0a0a0a] border border-gray-200 dark:border-white/10 rounded-lg p-3 text-black dark:text-white focus:border-black dark:border-white focus:ring-1 " required>
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-500 dark:text-gray-400 mb-2">Avatar URL (Optional)</label>
            <input type="url" name="avatar" value="<%= review.avatar || '' %>" class="w-full bg-white dark:bg-[#0a0a0a] border border-gray-200 dark:border-white/10 rounded-lg p-3 text-black dark:text-white focus:border-black dark:border-white focus:ring-1 " placeholder="https://...">
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-500 dark:text-gray-400 mb-2">Comment</label>
            <textarea name="comment" rows="4" class="w-full bg-white dark:bg-[#0a0a0a] border border-gray-200 dark:border-white/10 rounded-lg p-3 text-black dark:text-white focus:border-black dark:border-white focus:ring-1 " required><%= review.comment || '' %></textarea>
        </div>

        <div class="pt-6 border-t border-gray-200 dark:border-white/10 flex justify-end gap-4">
             <a href="/admin/reviews" class="px-6 py-3 border border-gray-300 dark:border-white/20 hover:bg-gray-200 dark:bg-gray-800 text-gray-600 dark:text-gray-300 font-medium rounded-lg transition-colors">Cancel</a>
            <button type="submit" class="px-8 py-3 bg-black text-white hover:bg-gray-800 dark:bg-white dark:text-black dark:hover:bg-gray-200 font-medium rounded-lg shadow-lg">Save Review</button>
        </div>

    </form>
</div>
