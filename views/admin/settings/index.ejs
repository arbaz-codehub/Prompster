<div class="max-w-4xl mx-auto bg-gray-50 dark:bg-[#111111] rounded-xl border border-gray-200 dark:border-white/10 p-8">
    <div class="mb-8">
        <h2 class="text-2xl font-bold text-black dark:text-white">Global Settings</h2>
        <p class="text-gray-500 dark:text-gray-400 mt-2">Manage dynamic options for your application.</p>
    </div>

    <form action="/admin/settings" method="POST" class="space-y-6">
        
        <!-- Product Types -->
        <div>
            <label class="block text-sm font-medium text-gray-500 dark:text-gray-400 mb-2">Product Types (Comma Separated)</label>
            <p class="text-xs text-gray-500 mb-2">These options will appear in the "Type" dropdown. (e.g. Prompts, Other Assets)</p>
            <textarea name="product_types" rows="2" class="w-full bg-white dark:bg-[#0a0a0a] border border-gray-200 dark:border-white/10 rounded p-2.5 text-black dark:text-white focus:border-black dark:border-white"><%= typeValues %></textarea>
        </div>

        <!-- Product Categories -->
        <div>
            <label class="block text-sm font-medium text-gray-500 dark:text-gray-400 mb-2">Product Categories (Comma Separated)</label>
            <p class="text-xs text-gray-500 mb-2">These are the filterable categories for the Marketplace.</p>
            <textarea name="product_categories" rows="2" class="w-full bg-white dark:bg-[#0a0a0a] border border-gray-200 dark:border-white/10 rounded p-2.5 text-black dark:text-white focus:border-black dark:border-white"><%= categoryValues %></textarea>
        </div>

        <!-- Prompt Categories -->
        <div>
            <label class="block text-sm font-medium text-gray-500 dark:text-gray-400 mb-2">Prompt Types / Categories (Comma Separated)</label>
            <p class="text-xs text-gray-500 mb-2">These are the primary filter options for the Browse Prompts page.</p>
            <textarea name="prompt_categories" rows="2" class="w-full bg-white dark:bg-[#0a0a0a] border border-gray-200 dark:border-white/10 rounded p-2.5 text-black dark:text-white focus:border-black dark:border-white"><%= promptCategoryValues %></textarea>
        </div>

        <!-- Product Formats -->
        <div>
            <label class="block text-sm font-medium text-gray-500 dark:text-gray-400 mb-2">Product Formats (Comma Separated)</label>
            <p class="text-xs text-gray-500 mb-2">These options will appear in the "Format" dropdown when adding/editing products.</p>
            <textarea name="product_formats" rows="3" class="w-full bg-white dark:bg-[#0a0a0a] border border-gray-200 dark:border-white/10 rounded p-2.5 text-black dark:text-white focus:border-black dark:border-white focus:ring-1 "><%= formatValues %></textarea>
        </div>

        <!-- Blog Password -->
        <div class="border-t border-gray-200 dark:border-white/10 pt-6 mt-6">
            <h3 class="text-xl font-bold text-black dark:text-white mb-2">Blog Access Level</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">Set a separate password to grant access exclusively to the Blog section. Leave empty to keep it unset or unchanged.</p>
            <div>
                <label class="block text-sm font-medium text-gray-500 dark:text-gray-400 mb-2">Blog Password (Optional)</label>
                <input type="password" name="blog_password" placeholder="Enter a new blog password to update" class="w-full bg-white dark:bg-[#0a0a0a] border border-gray-200 dark:border-white/10 rounded p-2.5 text-black dark:text-white focus:border-black dark:border-white focus:ring-1 ">
                <% if (blogPwdIsSet) { %>
                    <p class="text-xs text-green-400 mt-2">✓ A blog password is currently set.</p>
                <% } else { %>
                    <p class="text-xs text-yellow-500 mt-2">⚠ No blog password set. Only the main Admin can access the admin panel.</p>
                <% } %>
            </div>
        </div>

        <div class="pt-6 border-t border-gray-200 dark:border-white/10 flex justify-end">
            <button type="submit" class="px-6 py-3 bg-black text-white hover:bg-gray-800 dark:bg-white dark:text-black dark:hover:bg-gray-200 font-medium rounded transition">Save Settings</button>
        </div>

    </form>
</div>
